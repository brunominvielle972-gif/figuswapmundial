rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS COLLECTION SECURING ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Users need to see other collector profiles to map names
      allow write: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(incoming());
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt'])
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100;
    }

    // --- STICKERS CATALOG SECURING ---
    match /stickers/{stickerId} {
      allow read, list: if isSignedIn(); // Free search capabilities are needed for finding collectors
      
      allow create: if isSignedIn() 
        && incoming().ownerId == request.auth.uid 
        && isValidSticker(incoming())
        && incoming().updatedAt is string;
        
      allow update: if isSignedIn() 
        && existing().ownerId == request.auth.uid 
        && incoming().ownerId == request.auth.uid 
        && isValidSticker(incoming())
        && incoming().updatedAt is string;

      allow delete: if isSignedIn() 
        && existing().ownerId == request.auth.uid;
    }

    function isValidSticker(data) {
      return data.keys().hasAll(['ownerId', 'ownerName', 'code', 'playerName', 'country', 'type', 'isShiny', 'quantity', 'updatedAt'])
        && (data.keys().size() == 9 || (data.keys().size() == 10 && 'id' in data))
        && data.code is string && data.code.size() <= 10
        && data.playerName is string && data.playerName.size() <= 80
        && data.country is string && data.country.size() <= 50
        && (data.type == 'repetida' || data.type == 'faltante')
        && data.isShiny is bool
        && (data.quantity is int || data.quantity is float) && data.quantity >= 1 && data.quantity <= 100;
    }

    // --- TRADE AGREEMENTS SECURING ---
    match /trades/{tradeId} {
      allow read, list: if isSignedIn(); // Standard collection list reads are permitted for mutual matchmaking

      allow create: if isSignedIn() 
        && incoming().proposerId == request.auth.uid 
        && isValidTrade(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt is string;

      // Tiered Identity Logic for Updating Trades
      allow update: if isSignedIn() 
        && (existing().proposerId == request.auth.uid || existing().receiverId == request.auth.uid)
        && isValidTrade(incoming())
        && incoming().proposerId == existing().proposerId
        && incoming().receiverId == existing().receiverId
        && (
          // Action 1: Receiver accepts or rejects
          (request.auth.uid == existing().receiverId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
          // Action 2: Either party completes or cancels the trade (Terminal lock transition)
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        )
        && incoming().updatedAt is string;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['id', 'proposerId', 'proposerName', 'receiverId', 'receiverName', 'offeredStickers', 'requestedStickers', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() == 10
        && data.proposerId is string && data.proposerId.size() <= 128
        && data.receiverId is string && data.receiverId.size() <= 128
        && data.proposerName is string && data.proposerName.size() <= 100
        && data.receiverName is string && data.receiverName.size() <= 100
        && (data.status == 'pending' || data.status == 'accepted' || data.status == 'rejected' || data.status == 'completed' || data.status == 'cancelled')
        && data.offeredStickers is list
        && data.requestedStickers is list;
    }

    // --- TRADE MESSAGES (SUBCOLLECTION) SECURING ---
    match /trades/{tradeId}/messages/{messageId} {
      allow read, list, create: if isSignedIn() 
        && (
          get(/databases/$(database)/documents/trades/$(tradeId)).data.proposerId == request.auth.uid 
          || get(/databases/$(database)/documents/trades/$(tradeId)).data.receiverId == request.auth.uid
        );
    }

    // --- FRIEND REQUESTS SECURING ---
    match /friendRequests/{requestId} {
      allow read, list: if isSignedIn();
      
      allow create: if isSignedIn() 
        && (incoming().senderId == request.auth.uid || incoming().receiverId == request.auth.uid) 
        && isValidFriendRequest(incoming());
        
      allow update: if isSignedIn() 
        && (existing().receiverId == request.auth.uid || existing().senderId == request.auth.uid) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['status']) 
        && (incoming().status == 'accepted' || incoming().status == 'rejected');
        
      allow delete: if isSignedIn() 
        && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
    }

    function isValidFriendRequest(data) {
      return data.keys().hasAll(['id', 'senderId', 'senderName', 'receiverId', 'receiverName', 'status', 'createdAt'])
        && data.keys().size() == 7
        && data.senderId is string && data.senderId.size() <= 128
        && data.receiverId is string && data.receiverId.size() <= 128
        && data.senderName is string && data.senderName.size() <= 100
        && data.receiverName is string && data.receiverName.size() <= 100
        && (data.status == 'pending' || data.status == 'accepted' || data.status == 'rejected')
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

  }
}
